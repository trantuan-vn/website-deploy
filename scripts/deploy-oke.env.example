# Copy to production.env (repo root) and fill in real values. Do not commit production.env.
#
# cp scripts/deploy-oke.env.example production.env

# --- OCIR ---
OCIR_REGION=ap-singapore-1
# Tenancy namespace OCIR (KHÔNG phải tên compartment). Lấy bằng: oci os ns get
OCIR_TENANCY_NAMESPACE=your-tenancy-namespace
OCIR_USERNAME=your-oci-username
# Bọc trong dấu nháy đơn nếu token có ; [ ] $ …
OCIR_AUTH_TOKEN='your-auth-token'
OCIR_EMAIL=you@example.com
# Tăng mỗi lần deploy code mới (v1.0.1, v1.0.2, …). Tránh dùng mãi một tag.
IMAGE_TAG=v1.0.0

# --- Domain ---
DOMAIN=vcpp.vn
NEXT_PUBLIC_SERVER_URL=https://vcpp.vn

# --- App secrets (random, ≥ 32 chars for PAYLOAD_SECRET) ---
DATABASE_URL=mongodb://mongo.website.svc.cluster.local:27017/website-deploy
PAYLOAD_SECRET=replace-with-random-secret-min-32-chars
CRON_SECRET=replace-with-random-secret
PREVIEW_SECRET=replace-with-random-secret

# --- Build-time (Mongo reachable from Docker on your machine during docker build) ---
# Mac/Win + mongo local:  mongodb://host.docker.internal:27017/website-deploy
# Port-forward cluster:   kubectl port-forward -n website svc/mongo 27017:27017
#                         BUILD_DATABASE_URL=mongodb://127.0.0.1:27017/website-deploy
# Không dùng mongo.website.svc.cluster.local ở đây — chỉ resolve trong K8s.
BUILD_DATABASE_URL=mongodb://host.docker.internal:27017/website-deploy
BUILD_PAYLOAD_SECRET=build-time-secret-min-32-chars

# --- TLS (Cloudflare Origin Certificate paths, relative to repo root) ---
ORIGIN_CERT=origin.pem
ORIGIN_KEY=origin.key

# --- Options ---
DEPLOY_MONGO=true
# Platform image Docker (tùy chọn). Mặc định auto-detect từ OKE node: arm64 → linux/arm64
# DOCKER_PLATFORM=linux/arm64
